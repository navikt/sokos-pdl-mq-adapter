{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nav.no/pdl/person/mq/aapenPersonPdlDokumentV1Mq.schema.json",
  "title": "Sync melding fra kafka for person på id og navn",
  "description": "Sync melding fra kafka for person på id og navn",
  "type": "object",
  "properties": {
    "ident": {
      "description": "Unik id for en person",
      "type": "string"
    },
    "navn": {
      "$ref": "#/$defs/navn"
    },
    "folkeregisteridentifikatorTilMq": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/FolkeregisteridentifikatorTilMq"
      },
      "description": "List av Identer til person."
    }
  },
  "required": [
    "ident",
    "personInfo"
  ],
  "$defs": {
    "navn": {
      "type": "object",
      "properties": {
        "fornavn": {
          "type": [
            "string",
            "null"
          ]
        },
        "mellomnavn": {
          "type": [
            "string",
            "null"
          ]
        },
        "etternavn": {
          "type": [
            "string",
            "null"
          ]
        },
        "forkortetNavn": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "$ref": "#/$defs/MetadataTilMq"
        }
     }
   },
  "FolkeregisteridentifikatorTilMq": {
    "type": "array",
    "properties": {
      "identifikasjonsnummer": {
        "type": "string",
        "example": "24117920441",
        "description": "Ident til person."
      },
      "type": {
        "type": "string",
        "example": "DNR, FNR",
        "description": "Hva slags identifikator DNR eller FNR"
      },
      "status": {
        "type": "string",
        "example": "I_BRUK, OPPHOERT",
        "description": "Hva slags identifikator I_BRUK eller OPPHOERT"
      },
      "metadata": {
        "$ref": "#/$defs/MetadataTilMq"
      }
    }
  },
  "MetadataTilMq": {
    "type": "object",
    "properties": {
      "endringer": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/EndringerTilMq"
        },
        "description": "List av Endringer til person navn eller ident."
      },
      "historisk": "boolean"
    }
  },
  "EndringerTilMq": {
    "type": "object",
    "properties": {
      "type": {
        "type": "string",
        "example": true,
        "description": "OPRETT eller KORRIGERT"
      },
      "registrert": {
        "type": "string"
      }
    }
  }
 }
}